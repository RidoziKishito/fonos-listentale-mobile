<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/chat_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_island_glass"
        android:padding="12dp"
        android:elevation="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/button_chat_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/slate_900" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_chat_session_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Chat with Book AI"
                android:textColor="@color/slate_900"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/text_chat_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ListenTale AI Assistant"
                android:textColor="@color/primary_600"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/button_chat_sessions_history"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_recent_history"
            app:tint="@color/slate_900"
            android:contentDescription="Chat History" />
    </LinearLayout>

    <!-- Active Book Pill Selector Bar -->
    <LinearLayout
        android:id="@+id/chat_book_context_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_island_glass"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chat_header">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/image_active_book_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <TextView
            android:id="@+id/text_active_book_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="10dp"
            android:fontFamily="sans-serif-bold"
            android:text="You have to choose a book"
            android:textColor="@color/slate_800"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_change_or_add_book"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="@color/primary_light"
            android:text="Change/Add Book +"
            android:textColor="@color/primary_700"
            android:textSize="11sp"
            android:textStyle="bold"
            app:cornerRadius="10dp"
            android:paddingHorizontal="10dp" />

    </LinearLayout>

    <!-- Messages Recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_chat_messages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginVertical="8dp"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/chat_input_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chat_book_context_bar"
        tools:listitem="@layout/item_chat_message_ai" />

    <!-- Bottom Input Glass Bar -->
    <LinearLayout
        android:id="@+id/chat_input_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_island_glass"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <EditText
            android:id="@+id/edit_text_chat_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@null"
            android:hint="Ask a question about the book..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textColor="@color/slate_900"
            android:textColorHint="@color/slate_400"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/button_send_message"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_white_alpha"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/primary_600" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
