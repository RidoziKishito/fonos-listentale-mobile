<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/outline_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/image_book_cover"
                android:layout_width="88dp"
                android:layout_height="110dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                app:shapeAppearanceOverlay="@style/RoundedImage" />

            <CheckBox
                android:id="@+id/checkbox_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="-8dp"
                android:visibility="gone"
                android:button="@drawable/sl_checkbox"
                android:buttonTint="@null"
                app:buttonTint="@null" />

            <ImageView
                android:id="@+id/image_premium_lock"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_lock"
                android:visibility="gone"
                app:tint="@color/white"
                android:alpha="0.8" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-bold"
                android:maxLines="1"
                android:text="Book Title"
                android:textColor="@color/slate_900"
                android:textStyle="bold"
                android:textSize="19sp" />

            <TextView
                android:id="@+id/text_book_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Author Name"
                android:textColor="@color/slate_600"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_book_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0h 0m"
                    android:textColor="@color/slate_400"
                    android:textSize="12sp" />

                <View android:layout_width="1dp" android:layout_height="12dp" android:background="@color/slate_200" android:layout_marginHorizontal="8dp" android:layout_gravity="center_vertical"/>

                <TextView
                    android:id="@+id/text_book_pages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pages"
                    android:textColor="@color/slate_400"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_book_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_category_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Fantasy"
                android:textColor="@color/primary_600"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <ImageButton
                android:id="@+id/button_play_item"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/primary_600" />

            <ImageButton
                android:id="@+id/button_read_item"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Read book"
                android:src="@drawable/ic_read_book"
                app:tint="@color/violet_600" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
