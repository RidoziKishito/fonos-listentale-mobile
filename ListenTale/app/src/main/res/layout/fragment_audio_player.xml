<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_900">

    <ImageView
        android:id="@+id/image_player_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_player_overlay" />

    <!-- Header -->
    <ImageButton
        android:id="@+id/button_player_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <ImageButton
        android:id="@+id/button_player_add_bookmark"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_bookmark_add"
        app:tint="@color/white"
        app:layout_constraintEnd_toStartOf="@id/button_player_bookmarks"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Add Bookmark" />

    <ImageButton
        android:id="@+id/button_player_bookmarks"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_bookmark_list"
        app:tint="@color/white"
        app:layout_constraintEnd_toStartOf="@id/layout_timer_header"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Bookmarks List" />

    <FrameLayout
        android:id="@+id/layout_timer_header"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toStartOf="@id/button_player_ai_chat"
        app:layout_constraintTop_toTopOf="parent">
        <ImageButton
            android:id="@+id/button_player_timer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_lock_idle_alarm"
            app:tint="@color/white" />
        <TextView
            android:id="@+id/text_timer_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:background="@color/violet_600"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:paddingHorizontal="4dp"
            android:visibility="gone" />
    </FrameLayout>

    <ImageButton
        android:id="@+id/button_player_ai_chat"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_ai_sparkles"
        app:tint="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Ask AI Chat" />

    <!-- Artwork -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_artwork"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="48dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="24dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_player_back"
        app:layout_constraintBottom_toTopOf="@id/text_player_title"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/image_player_artwork"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_gallery" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Info -->
    <TextView
        android:id="@+id/text_player_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-black"
        android:text="Book Title"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:paddingHorizontal="24dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/card_artwork" />

    <TextView
        android:id="@+id/text_player_author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Author Name"
        android:textColor="@color/slate_400"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_player_title" />

    <LinearLayout
        android:id="@+id/layout_speed_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:background="@drawable/bg_speed_pill"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_player_author">

        <TextView
            android:id="@+id/text_current_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0x"
            android:textColor="@color/slate_400"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Progress -->
    <com.google.android.material.slider.Slider
        android:id="@+id/player_slider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp"
        android:value="0"
        android:valueFrom="0"
        android:valueTo="100"
        app:layout_constraintTop_toBottomOf="@id/layout_speed_control"
        app:thumbColor="@color/white"
        app:trackColorActive="@color/violet_500"
        app:trackColorInactive="#33FFFFFF" />

    <TextView
        android:id="@+id/text_player_current_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="00:00"
        android:textColor="@color/slate_400"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/player_slider"
        app:layout_constraintTop_toBottomOf="@id/player_slider" />

    <TextView
        android:id="@+id/text_player_total_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="00:00"
        android:textColor="@color/slate_400"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@id/player_slider"
        app:layout_constraintTop_toBottomOf="@id/player_slider" />

    <!-- Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/player_slider"
        app:layout_constraintVertical_bias="0.5">

        <ImageButton
            android:id="@+id/button_player_prev"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/white" />

        <FrameLayout
            android:id="@+id/button_player_rewind_15"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="12dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_rew"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="15"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:clickable="false" />
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/button_play_container"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="40dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">
            <ImageButton
                android:id="@+id/fab_play_pause"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_media_play"
                app:tint="@color/slate_900" />
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/button_player_forward_30"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="12dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:src="@android:drawable/ic_media_ff"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="30"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:clickable="false" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/button_player_next"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            app:tint="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>