<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp">

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_circle_white_alpha"
        android:padding="6dp"
        android:src="@drawable/ic_ai_sparkles"
        app:tint="@color/primary_600" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_message_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="280dp"
            android:background="@drawable/bg_chat_ai_bubble"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:text="AI response text..."
            android:textColor="@color/slate_800"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp" />

        <TextView
            android:id="@+id/text_message_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="12:01"
            android:textColor="@color/slate_400"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>
