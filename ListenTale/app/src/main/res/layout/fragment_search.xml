<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_island_glass"
        android:orientation="vertical"
        android:paddingBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_search_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="Search"
            android:textColor="@color/slate_900"
            android:textSize="32sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_search_layout"
            style="@style/Widget.Material3.TextInputLayout.FilledBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:hintEnabled="false"
            app:boxBackgroundColor="@color/white"
            app:boxCornerRadiusBottomEnd="20dp"
            app:boxCornerRadiusBottomStart="20dp"
            app:boxCornerRadiusTopEnd="20dp"
            app:boxCornerRadiusTopStart="20dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:hintTextColor="@color/slate_500"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/primary_600">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Books, authors, or topics"
                android:inputType="text"
                android:paddingVertical="12dp"
                android:textColor="@color/slate_900"
                android:background="@null"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:text="Top Categories"
                    android:textColor="@color/slate_900"
                    android:textSize="22sp" />
                
                <ImageButton
                    android:id="@+id/btn_filter_genres"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/slate_700"/>
            </LinearLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_romance"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Romance"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/primary_light"
                    app:chipStrokeColor="@color/primary_200"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/primary_600"
                    app:rippleColor="@color/primary_200"
                    android:textColor="@color/primary_700"
                    app:chipCornerRadius="24dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_self_help"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Self-Help"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/accent_soft"
                    app:chipStrokeColor="#FFC9C9"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/accent_vibrant"
                    app:rippleColor="#22FF6B6B"
                    android:textColor="@color/slate_700"
                    app:chipCornerRadius="24dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_philosophy"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Philosophy"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/sky_200"
                    app:chipStrokeColor="#7DD3FC"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/primary_700"
                    android:textColor="@color/slate_700"
                    app:chipCornerRadius="24dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_classic"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Classic"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/sunshine_200"
                    app:chipStrokeColor="#FCD34D"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/amber_500"
                    android:textColor="@color/slate_700"
                    app:chipCornerRadius="24dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_mystery"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mystery"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/white"
                    app:chipStrokeColor="@color/primary_200"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/primary_600"
                    android:textColor="@color/slate_700"
                    app:chipCornerRadius="24dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_children"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Children"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/primary_light"
                    app:chipStrokeColor="@color/primary_200"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconTint="@color/primary_600"
                    android:textColor="@color/primary_700"
                    app:chipCornerRadius="24dp" />
            </com.google.android.material.chip.ChipGroup>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_search_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="-8dp"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2" />

            <TextView
                android:id="@+id/text_recent_searches_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-bold"
                android:text="Recent Searches"
                android:textColor="@color/slate_900"
                android:textSize="22sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recent_searches"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
