<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_50"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:elevation="4dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="48dp"
            android:backgroundTint="@color/white">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/image_profile_avatar"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:padding="6dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="@color/primary_light"
                    app:strokeWidth="6dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/icon_edit_avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    app:backgroundTint="@color/primary_600"
                    app:tint="@color/white"
                    app:fabCustomSize="30dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="Edit avatar" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Alex Johnson"
                android:textColor="@color/slate_900"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/text_profile_membership"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Premium Member"
                android:textColor="@color/primary_600"
                android:textStyle="bold"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="124"
                        android:textColor="@color/slate_900"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Books"
                        android:textColor="@color/slate_500"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:layout_marginHorizontal="32dp"
                    android:background="@color/slate_200" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="45"
                        android:textColor="@color/slate_900"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reviews"
                        android:textColor="@color/slate_500"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_upgrade_account"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/primary_600"
                android:gravity="start|center_vertical"
                android:text="Upgrade Account"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="24dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconSize="24dp"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_account_info"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/white"
                android:gravity="start|center_vertical"
                android:text="Account Info"
                android:textAllCaps="false"
                android:textColor="@color/slate_800"
                android:textSize="16sp"
                app:cornerRadius="24dp"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconSize="24dp"
                app:iconTint="@color/primary_600" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_downloaded"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/white"
                android:gravity="start|center_vertical"
                android:text="Downloaded"
                android:textAllCaps="false"
                android:textColor="@color/slate_800"
                android:textSize="16sp"
                app:cornerRadius="24dp"
                app:icon="@android:drawable/stat_sys_download_done"
                app:iconSize="24dp"
                app:iconTint="@color/primary_600" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_settings"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/white"
                android:gravity="start|center_vertical"
                android:text="Settings"
                android:textAllCaps="false"
                android:textColor="@color/slate_800"
                android:textSize="16sp"
                app:cornerRadius="24dp"
                app:icon="@android:drawable/ic_menu_manage"
                app:iconSize="24dp"
                app:iconTint="@color/primary_600" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_logout"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/red_50"
                android:gravity="start|center_vertical"
                android:text="Log Out"
                android:textAllCaps="false"
                android:textColor="@color/red_600"
                android:textSize="16sp"
                app:cornerRadius="24dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconSize="24dp"
                app:iconTint="@color/red_600" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>