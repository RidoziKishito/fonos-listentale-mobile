<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Top Profile Header Glass Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_island_glass"
            android:elevation="6dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="28dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/image_profile_avatar"
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:padding="3dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="@color/primary_600"
                    app:strokeWidth="3dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/icon_edit_avatar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    app:backgroundTint="@color/primary_600"
                    app:tint="@color/white"
                    app:fabCustomSize="32dp"
                    android:src="@android:drawable/ic_menu_camera"
                    android:contentDescription="Edit avatar" />
            </FrameLayout>

            <TextView
                android:id="@+id/text_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-black"
                android:text="Alex Johnson"
                android:textColor="@color/slate_900"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/text_profile_membership"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_badge_pill_glass"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:text="PREMIUM MEMBER"
                android:textColor="@color/primary_700"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Rank & Linear Progress Glass Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_island_glass"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_rank_icon_container"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/image_rank_badge"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="@color/primary_600" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/text_rank_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Level 1 • Beginner"
                        android:textColor="@color/slate_900"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/text_rank_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="The journey of a thousand pages begins"
                        android:textColor="@color/slate_600"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_rank"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="16dp"
                android:progressDrawable="@drawable/bg_rank_progress_bar"
                android:progress="35"
                android:max="100" />

            <TextView
                android:id="@+id/text_rank_progress_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-bold"
                android:text="35% to Level 2 • Explorer (1/3 books completed)"
                android:textColor="@color/primary_700"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Personal Dashboard Stats Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <!-- Card 1: Time Listened -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_island_glass"
                android:elevation="4dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/text_stat_hours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="0m"
                    android:textColor="@color/primary_700"
                    android:textSize="18sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Listened"
                    android:textColor="@color/slate_600"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Card 2: Books Completed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_island_glass"
                android:elevation="4dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/text_stat_books_completed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="0"
                    android:textColor="@color/primary_700"
                    android:textSize="18sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Completed"
                    android:textColor="@color/slate_600"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Card 3: Top Genre -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_island_glass"
                android:elevation="4dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/text_stat_top_genre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="General"
                    android:textColor="@color/primary_700"
                    android:textSize="15sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="Top Genre"
                    android:textColor="@color/slate_600"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Account Management Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_upgrade_account"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/primary_600"
                android:gravity="start|center_vertical"
                android:text="Upgrade Account"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconSize="20dp"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_account_info"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="start|center_vertical"
                android:text="Account Information"
                android:textAllCaps="false"
                android:textColor="@color/slate_900"
                android:textSize="15sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_myplaces"
                app:iconSize="20dp"
                app:iconTint="@color/primary_600" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_downloaded"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="start|center_vertical"
                android:text="Downloaded Books"
                android:textAllCaps="false"
                android:textColor="@color/slate_900"
                android:textSize="15sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/stat_sys_download_done"
                app:iconSize="20dp"
                app:iconTint="@color/primary_600" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_settings"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="start|center_vertical"
                android:text="Settings"
                android:textAllCaps="false"
                android:textColor="@color/slate_900"
                android:textSize="15sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_manage"
                app:iconSize="20dp"
                app:iconTint="@color/primary_600" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_logout"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/red_50"
                android:gravity="start|center_vertical"
                android:text="Log Out"
                android:textAllCaps="false"
                android:textColor="@color/red_600"
                android:textSize="15sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconSize="20dp"
                app:iconTint="@color/red_600" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>