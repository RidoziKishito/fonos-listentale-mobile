<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment">

    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.example.fonoss.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome">
        <action
            android:id="@+id/action_welcomeFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_welcomeFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.fonoss.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_booksFragment"
            app:destination="@id/booksFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.fonoss.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_booksFragment"
            app:destination="@id/booksFragment"
            app:popUpTo="@id/welcomeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/booksFragment"
        android:name="com.example.fonoss.BooksFragment"
        android:label="Books"
        tools:layout="@layout/fragment_books">
        <action
            android:id="@+id/action_booksFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
        <action
            android:id="@+id/action_booksFragment_to_seeAllFragment"
            app:destination="@id/seeAllFragment" />
        <action
            android:id="@+id/action_booksFragment_to_audioPlayerFragment"
            app:destination="@id/audioPlayerFragment" />
        <action
            android:id="@+id/action_booksFragment_to_ebookReaderFragment"
            app:destination="@id/ebookReaderFragment" />
    </fragment>

    <fragment
        android:id="@+id/seeAllFragment"
        android:name="com.example.fonoss.SeeAllFragment"
        android:label="See All"
        tools:layout="@layout/fragment_see_all">
        <action
            android:id="@+id/action_seeAllFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
        <action
            android:id="@+id/action_seeAllFragment_to_audioPlayerFragment"
            app:destination="@id/audioPlayerFragment" />
        <action
            android:id="@+id/action_seeAllFragment_to_ebookReaderFragment"
            app:destination="@id/ebookReaderFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.fonoss.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_searchFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
        <action
            android:id="@+id/action_searchFragment_to_audioPlayerFragment"
            app:destination="@id/audioPlayerFragment" />
        <action
            android:id="@+id/action_searchFragment_to_ebookReaderFragment"
            app:destination="@id/ebookReaderFragment" />
    </fragment>

    <fragment
        android:id="@+id/libraryFragment"
        android:name="com.example.fonoss.LibraryFragment"
        android:label="Library"
        tools:layout="@layout/fragment_library">
        <action
            android:id="@+id/action_libraryFragment_to_bookDetailFragment"
            app:destination="@id/bookDetailFragment" />
        <action
            android:id="@+id/action_libraryFragment_to_audioPlayerFragment"
            app:destination="@id/audioPlayerFragment" />
        <action
            android:id="@+id/action_libraryFragment_to_ebookReaderFragment"
            app:destination="@id/ebookReaderFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.fonoss.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_accountInfoFragment"
            app:destination="@id/accountInfoFragment" />
        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/accountInfoFragment"
        android:name="com.example.fonoss.AccountInfoFragment"
        android:label="Account Info"
        tools:layout="@layout/fragment_account_info" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.fonoss.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/bookDetailFragment"
        android:name="com.example.fonoss.BookDetailFragment"
        android:label="Book Detail"
        tools:layout="@layout/fragment_book_detail">
        <action
            android:id="@+id/action_bookDetailFragment_to_audioPlayerFragment"
            app:destination="@id/audioPlayerFragment" />
        <action
            android:id="@+id/action_bookDetailFragment_to_ebookReaderFragment"
            app:destination="@id/ebookReaderFragment" />
    </fragment>

    <fragment
        android:id="@+id/ebookReaderFragment"
        android:name="com.example.fonoss.EbookReaderFragment"
        android:label="Ebook Reader"
        tools:layout="@layout/fragment_ebook_reader" />

    <fragment
        android:id="@+id/audioPlayerFragment"
        android:name="com.example.fonoss.AudioPlayerFragment"
        android:label="Audio Player"
        tools:layout="@layout/fragment_audio_player" />

</navigation>